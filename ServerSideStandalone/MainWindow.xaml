<Window x:Class="ServerSideStandalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServerSideStandalone"
        mc:Ignorable="d"
        Title="Server" Height="600" Width="1000">

<Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            
            <TextBlock Text="Connected Clients" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="ClientList" Height="200" Background="#2D2D2D" BorderThickness="0" Margin="0,0,0,15">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Expander Foreground="LightGreen" Width="500">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Username}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding uid, StringFormat=' (ID: {0})'}" FontSize="10" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Expander.Header>

                            <StackPanel Margin="10,5,0,5">
                                <TextBlock Text="{Binding IPAddress, StringFormat='IP: {0}'}" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{Binding Latency, StringFormat='Latency: {0}'}" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{Binding Skipped, StringFormat='Skipped: {0}'}" FontSize="11" Foreground="Gray"/>
                                <Separator Background="#444" Margin="0,5"/>
                                
                                <TextBlock Text="{Binding CurrentPage, StringFormat='Page: {0}'}" FontSize="11" Foreground="SkyBlue"/>
                                <TextBlock Text="{Binding Lobby, StringFormat='Lobby: {0}'}" FontSize="11" Foreground="SkyBlue"/>
                                
                                <Button Content="Kick Player" 
                                        Background="#442222" 
                                        Foreground="White" 
                                        Margin="0,8,0,0"
                                        Padding="5,2"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Active Lobbies" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="LobbyList" Height="300" Background="#2D2D2D" Foreground="SkyBlue" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                            
                            <StackPanel x:Name="DetailsArea" Visibility="Collapsed" Margin="10,5,0,0">
                                <TextBlock Text="{Binding PlayerCount, StringFormat='Players: {0}'}" Foreground="#AAA"/>
                                
                                <TextBlock Text="{Binding tps}" Foreground="#AAA"/>
                                
                                <TextBlock Text="{Binding Uptime}" Foreground="#AAA"/>
                                
                                <TextBlock Text="{Binding UserList}" Foreground="#777" FontStyle="Italic" TextWrapping="Wrap"/>
                                
                                <Button Content="Close Lobby" Margin="0,5,0,0" Click="OnCloseLobbyClick"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="DetailsArea" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBox x:Name="TerminalOutput" Grid.Row="0" IsReadOnly="True" 
                     Background="Black" Foreground="White" FontFamily="Consolas" 
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            
            <TextBox x:Name="TerminalInput" Grid.Row="1" Margin="0,10,0,0" 
                     Height="30" Background="#2D2D2D" Foreground="White"
                     VerticalContentAlignment="Center" KeyDown="OnInputKeyDown"/>
        </Grid>
    </Grid>
</Window>
