<Window x:Class="ServerSideStandalone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServerSideStandalone"
        mc:Ignorable="d"
        Title="Server" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MyStatusText" 
                   Grid.Row="0"
                   Text="Waiting..." 
                   FontSize="20" 
                   HorizontalAlignment="Center" 
                   Margin="10"/>

        <StackPanel Grid.Row="1" Margin="20">
            <Separator Margin="0,0,0,20"/>
            
            <TextBlock Text="Client Message:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="AlertTextBox" 
                     Text="Hello from the Server!" 
                     Margin="0,0,0,10"
                     Padding="5"/>
            
            <Button Content="Send Alert to All Clients" 
                    Click="SendAlert_Click" 
                    Height="40" 
                    Background="LightBlue"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>

</Window>
