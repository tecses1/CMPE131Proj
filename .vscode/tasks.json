{
  "version": "2.0.0",
  "tasks": [
{

      "label": "build-wasm",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/ClientSideWASM/ClientSideWASM.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ClientSideWASM"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-wpf",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/ServerSideStandalone/ServerSideStandalone.csproj"]
    }
  ]
}