{
  "version": "0.2.0",
  "configurations": [
{
      "name": "Launch Client (GAME)",
      "type": "blazorwasm",
      "request": "launch",
      "url": "http://localhost:5152",
      "browser": "chrome", 
      "webRoot": "${workspaceFolder}/ClientSideWASM",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "preLaunchTask": "build-wasm",
      "cwd": "${workspaceFolder}/ClientSideWASM",
      "timeout": 30000
    
    },
    {
      "name": "Launch Server (WPF)",
      "type": "coreclr", 
      "request": "launch",
      "preLaunchTask": "build-wpf",
      "program": "${workspaceFolder}/ServerSideStandalone/bin/Debug/net9.0-windows/ServerSideStandalone.exe",
      "args": [],
      "cwd": "${workspaceFolder}/ServerSideStandalone",
      "stopAtEntry": false
    }
  ],
  "compounds": [
    {
      "name": "Server + Client",
      "configurations": [
        "Launch Client (GAME)",
        "Launch Server (WPF)"
      ],
      "stopAll": true
    }
  ]
}