@page "/"
@layout MainLayout

@code{
    async Task Save(){
        await LocalStorage.SetItemAsStringAsync("settingsSaveKey",Settings.Save());

    }
    protected override async Task OnInitializedAsync()
    {

        //Initialize the network manager. COnnect to the server service.

        
        bool worked = Settings.Load(await LocalStorage.GetItemAsync<string>("settingsSaveKey"));
        if (!worked){
            await Save();
        }
        nm.Initialize();
        await Task.Delay(1000);

        
        if (nm.client.isConnected())
        {
            Nav.NavigateTo("/Home");//,true);
        }else{
            Nav.NavigateTo("/Error");//,true);
        }
        

    }
        
}