@page "/Home"
@layout MainLayout
@using Blazored.LocalStorage
@inject IJSRuntime JS 
@*Load resources defined in dictionary from asset manager*@
<!--<img @ref="_myImage" src="./spaceship.png" hidden /> -->
<div style="display:none">
    @foreach (var asset in AssetManager._assets.Values)
    {
        @for (int i = 0; i < asset.Frames.Length; i++)
        {
            var index = i; 
            <img @ref="asset.Frames[index]" 
                 src="@asset.FrameRefs[index]" 
                 alt="@asset.Name-@index" />
        }
    }
</div>
<PageTitle>Home</PageTitle>

<div class="canvas">
    <CanvasManager @ref="_canvasManager" />
    <div class="status">
        CMPE 131 Project | Benjamin Schnittker | Sofia Nguyen | Kekoa Sarmiento | Dylan Quach | Siddarth Kota
    </div>
</div>

<button @onclick="PlayBackgroundMusic">Play Music</button>
@* <button @onclick="StopBackgroundMusic">Stop Music</button> *@

@code {
    private async Task PlayBackgroundMusic()
    {
        await JS.InvokeVoidAsync("playAudio", "/audio/lobby_mus.mp3");
    }

    protected override async Task OnInitializedAsync()
    {
        // Automatically start background music
        await PlayBackgroundMusic();
    }
}